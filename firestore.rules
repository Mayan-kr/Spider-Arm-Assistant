rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only the authorized user (via email check in metadata) can write.
    // Read is allowed for the agent to sync status.
    match /commands/{docId} {
      allow write: if request.auth != null;
      allow read: if true;
    }
    match /system_status/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
